{
  "name": "missionforkids-functions",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "test": "firebase emulators:exec --only firestore,auth 'jest --runInBand --forceExit'"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "firebase-functions-test": "^3.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.2"
  },
  "private": true
}
