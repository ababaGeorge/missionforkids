rules_version = '2';

// =============================================================================
// 安全加固版（feat/security-hardening-demo）
// 修復項目（對照 2026-06-13 QA 審查報告）：
//   A1  小孩自批任務無限發點 → taskInstances 狀態流轉鎖：只有家長能 approve/reject
//   A3  任何人自升 parent / 跨家庭接管 → familyMemberships create/update 嚴格綁定
//   A4  兒童照片全表可讀 → taskSubmissions read 加家庭隔離
//   A5  email/個資全表可枚舉 → users list 鎖成只能查自己（get 仍放行，因 uid 已不可枚舉）
//   A6  小孩自批兌換訂單 → rewardOrders 狀態流轉鎖
//   A10 家庭關係圖可列舉 → familyMemberships read 加家庭隔離
//   A11 跨家庭注入垃圾 → 各 create 綁 isFamilyParent(該家庭)
//   A12 帳本/家庭名全表可讀 → pointTransactions read 鎖死、families read 加隔離
//   A16 邀請連結外洩讀 email → familyInvites get 僅限 pending 且未過期
// 核心原則維持：所有點數寫入只走 Cloud Functions（admin SDK，繞過本規則）。
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helper Functions ==========

    function isSignedIn() {
      return request.auth != null;
    }

    // 指定家庭的 active 成員（membership doc id = userId_familyId）
    function isFamilyMember(familyId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)) &&
        get(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)).data.status == 'active';
    }

    // 指定家庭的 active 家長
    function isFamilyParent(familyId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)) &&
        get(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)).data.role == 'parent' &&
        get(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)).data.status == 'active';
    }

    // update 專用：這次寫入「值真的有變」的欄位集合。
    // 用 diff() 而非逐欄等式比較——舊 doc 缺欄位時等式會 error→誤擋，
    // diff 只看被動到的欄位（R1 快照釘法同款理由，R2-CX1 推廣成通用白名單）。
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ========== Users ==========
    // get：放行已登入者讀單一 doc（家長需用 uid 直查小孩 user doc 顯示名字；
    //      uid 已無法被枚舉——familyMemberships list 已鎖，外人拿不到其他家庭的 uid）。
    // list：只能查自己（authProviderId == 自己 uid），擋掉全表 email 枚舉（A5）。
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.authProviderId == request.auth.uid;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // ========== Families ==========
    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      // R3 審查修正：建家庭只走 bootstrapParentAccount CF（admin，不受本規則限制）。
      // 原本放行 client 直建（handleCreateFamily 直寫）會讓惡意/舊 client 繞過
      // CF 的 ALREADY_IN_FAMILY 守衛（一帳號一家庭），自建第二個家庭。
      allow create: if false;
      allow update: if isFamilyParent(familyId);
    }

    // ========== Family Memberships ==========
    // doc id 格式: userId_familyId
    match /familyMemberships/{membershipId} {
      // 讀：自己的 membership（找自己的家庭）或同家庭成員（列成員）。擋全表枚舉（A10）。
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isFamilyMember(resource.data.familyId)
      );
      // R3 審查修正：membership 一律由 Cloud Functions(admin) 建立
      // （bootstrapParentAccount / acceptFamilyInvite），client 不可直建——
      // 原本的「自己剛建立的家庭可自建 parent membership」條款與 client 直建
      // family 一起構成繞過 ALREADY_IN_FAMILY 守衛的直寫路徑（A3 加強版）。
      allow create: if false;
      // 改：只有該家庭家長可改（暱稱/頭像），且 userId/familyId/role 不可變（擋自升 parent，A3）。
      // R3-3＋R3 審查修正：status 完全不可由 client 改——移除只走 removeFamilyMember CF、
      // reactivate 只走 acceptFamilyInvite CF（原本只禁寫成 'removed'，家長仍可把
      // removed 翻回 'active'，重造雙 active membership）。admin SDK 不受本規則限制。
      // 既有合法 client 更新只有 family.tsx handleSave（nickname/avatarEmoji，不動 status）→ 不受影響。
      allow update: if isFamilyParent(resource.data.familyId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.role == resource.data.role
        && !changedKeys().hasAny(['status']);
      allow delete: if false;
    }

    // ========== Family Invites（email 邀請）==========
    // inviteId 為隨機不可猜 doc id。get 僅限 pending 且未過期（A16：接受/過期後不再洩漏 email）。
    // list 禁止枚舉；寫入只走 Cloud Functions(admin)。
    match /familyInvites/{inviteId} {
      allow get: if resource.data.status == 'pending'
        && resource.data.expiresAt > request.time;
      allow list: if false;
      allow write: if false;
    }

    // ========== Tasks ==========
    match /tasks/{taskId} {
      allow read: if isFamilyMember(resource.data.familyId);
      // 只有該家庭家長能建任務（擋跨家庭注入 A11、擋小孩自建任務閉環 A1）
      allow create: if isFamilyParent(request.resource.data.familyId);
      allow update: if isFamilyParent(resource.data.familyId)
        && request.resource.data.familyId == resource.data.familyId;
      allow delete: if isFamilyParent(resource.data.familyId);
    }

    // ========== Task Instances ==========
    // A1 核心修復 + R2-CX1 狀態機（防禦縱深）：
    // R2 的交易守衛（updateInstanceIfStatusIn）只存在於新版 client——舊版 App 或
    // 直打 API 的 client 仍可裸 update。這裡把合法流轉矩陣直接編進 rules：
    // 不在矩陣內的 status 流轉一律拒絕，且每種流轉只准動白名單內的欄位
    // （changedKeys ⊆ 白名單 → 身分欄位 taskId/userId/childId/familyId 與
    // 點數欄位 pointsAwarded 天然被鎖，不用再逐欄等式釘）。
    //
    // 合法流轉矩陣（盤點自 src/ 全部 client 寫入點；詳見 R2-CX1 commit body）：
    //   家長  submitted → approved|rejected|missed   審核/三振（review.tsx）
    //         pending|rejected → missed              編輯移除（tasks.tsx markMissed）
    //         missed → pending                       復活（tasks.tsx revive，點數必須維持 null）
    //         status 不變，只動期限                    頻率改變同步（tasks.tsx syncPeriod）
    //   小孩  pending|rejected → submitted            提交（task/[id].tsx batch）
    //         rejected → pending                     重試/重拍（task/[id].tsx handleRetry）
    //   approved 是 client 終態（發點歷史）：任何 client 都不可再改。
    //   CF（admin SDK）不受本規則限制：發點回寫 pointsAwarded、週期任務自動生成。
    match /taskInstances/{instanceId} {
      allow read: if isFamilyMember(resource.data.familyId);
      // 建 instance 只有家長（發佈任務時），且必須以 pending 出生、不得預埋點數
      // （擋「出生即 approved」繞過狀態機）。週期任務未來由 CF(admin) 自動生成。
      allow create: if isFamilyParent(request.resource.data.familyId)
        && request.resource.data.status == 'pending'
        && request.resource.data.get('pointsAwarded', null) == null;
      allow update: if isFamilyMember(resource.data.familyId) && (
        (
          // ---- 家長 ----
          isFamilyParent(resource.data.familyId) && (
            // 審核：submitted → approved / rejected / missed(三振)
            (
              resource.data.status == 'submitted'
              && request.resource.data.status in ['approved', 'rejected', 'missed']
              && changedKeys().hasOnly(['status', 'reviewedBy', 'reviewedAt', 'parentNote'])
            )
            ||
            // 編輯移除：pending / rejected → missed（submitted→missed 已含在審核條款）
            (
              resource.data.status in ['pending', 'rejected']
              && request.resource.data.status == 'missed'
              && changedKeys().hasOnly(['status'])
            )
            ||
            // 復活：missed → pending（重設本期期限與審核欄位；pointsAwarded 只准維持 null）
            (
              resource.data.status == 'missed'
              && request.resource.data.status == 'pending'
              && changedKeys().hasOnly(['status', 'periodStart', 'periodEnd', 'gracePeriodEnd',
                                        'submissionCount', 'reviewedBy', 'reviewedAt', 'pointsAwarded'])
              && request.resource.data.get('pointsAwarded', null) == null
            )
            ||
            // 期限同步（頻率改變）：status 不變，只動期限欄位
            changedKeys().hasOnly(['periodEnd', 'gracePeriodEnd'])
          )
        )
        ||
        (
          // ---- 非家長成員（小孩）----
          // 提交：pending / rejected → submitted（交易同步寫計數與時間）
          // R3-4c：task 已封存（soft delete）→ 拒絕提交。client 交易守衛
          // （submitInstanceGuarded）只存在於新版 App，這裡把後端也關上，
          // 舊版 client / 直打 API 一樣擋住。task doc 不存在時 get() 取 data
          // 會 error → 條件為 false → 同樣拒絕，語意正確。
          (
            resource.data.status in ['pending', 'rejected']
            && request.resource.data.status == 'submitted'
            && changedKeys().hasOnly(['status', 'submissionCount', 'submittedAt'])
            && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.status != 'archived'
          )
          ||
          // 重試/重拍：rejected → pending
          (
            resource.data.status == 'rejected'
            && request.resource.data.status == 'pending'
            && changedKeys().hasOnly(['status'])
          )
        )
      );
    }

    // ========== Task Submissions ==========
    // A4 修復：read 加家庭隔離（client 查詢已改為帶 where familyId）。
    // 已知接受的邊界（R3-4 審查揭露）：create 不查對應 task 是否 archived——對封存任務
    // 單獨 create 一筆 submission 會成功、留下孤兒 doc。無點數/審核影響（審核流讀的是
    // submitted 的 taskInstance，該轉移已被上方 archived 檢查擋住）；要擋需對每筆 create
    // 多兩次 get()（submission 只有 taskInstanceId，得 instance→task 兩跳），成本不值。
    match /taskSubmissions/{submissionId} {
      allow read: if isFamilyMember(resource.data.familyId);
      // 小孩提交：必須是該家庭成員、submittedBy 是自己
      allow create: if isFamilyMember(request.resource.data.familyId)
        && request.resource.data.submittedBy == request.auth.uid;
      // 家長退回時寫 rejectNote
      allow update: if isFamilyParent(resource.data.familyId);
    }

    // ========== Point Wallets ==========
    // 讀：同家庭成員（含小孩讀自己錢包、家長讀小孩錢包）。寫入一律只走 Cloud Functions。
    match /pointWallets/{walletId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create, update, delete: if false;
    }

    // ========== Point Transactions ==========
    // A12 修復：帳本只有 Cloud Functions(admin) 讀寫，client 一律不可讀（目前 App 無任何 client 讀取）。
    match /pointTransactions/{transactionId} {
      allow read: if false;
      allow write: if false;
    }

    // ========== Reward Items ==========
    match /rewardItems/{itemId} {
      allow read: if isFamilyMember(resource.data.familyId);
      // 只有家長能建/改獎勵（擋跨家庭注入 A11）
      allow create: if isFamilyParent(request.resource.data.familyId);
      allow update: if isFamilyParent(resource.data.familyId)
        && request.resource.data.familyId == resource.data.familyId;
    }

    // ========== Reward Orders ==========
    // A6 修復 + R2-CX1 狀態機（防禦縱深）：
    // R2 的交易守衛（updateOrderIfStatusIn）只存在於新版 client——舊版 App 或
    // 直打 API 的 client 仍可裸 update（例：cancelled→approved = 退款已發生還免費領獎）。
    // 這裡把合法流轉矩陣直接編進 rules，每種流轉配欄位白名單（changedKeys ⊆ 白名單）：
    // 身分/金額欄位（familyId/itemId/userId/childId/pointCostSnapshot）與 CF 權威快照
    // （balanceBeforeSnapshot/balanceAfterSnapshot，R1/P8 對帳用）不在任何白名單 → 天然被鎖，
    // 取代原本的逐欄等式釘（等式對缺欄位的舊訂單會 error→誤擋，diff/白名單沒這問題）。
    //
    // 合法流轉矩陣（盤點自 src/ 全部 client 寫入點；詳見 R2-CX1 commit body）：
    //   家長  pending → approved                     核准（review.tsx）
    //         pending → rejected                     婉拒（review.tsx；退款 CF 對 rejected 觸發）
    //         approved → delivered                   交付（rewards.tsx）
    //   小孩  approved|delivered → completed          確認收到（order/[id].tsx）
    //         pending → cancelled                    取消（order/[id].tsx；退款 CF 觸發）
    //   cancelled / rejected / completed 是 client 終態：任何 client 都不可再改
    //   （擋「退款後改回 approved 免費領獎」）。CF/admin（扣款快照回寫、autoComplete、
    //   餘額不足改 rejected）不受本規則限制。
    match /rewardOrders/{orderId} {
      allow read: if isFamilyMember(resource.data.familyId);
      // 小孩建自己的訂單，初始 pending。
      // balanceBeforeSnapshot/balanceAfterSnapshot 是 CF 扣款時才寫的 server 權威快照，
      // create 時禁止預埋——成功路徑 CF 會覆寫沒事，但被拒訂單（品項無效/沒錢包/餘額不足）
      // 只改 status，client 預埋的偽值會殘留在 doc 上污染對帳。
      allow create: if isFamilyMember(request.resource.data.familyId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && !request.resource.data.keys().hasAny(['balanceBeforeSnapshot', 'balanceAfterSnapshot']);
      allow update: if isFamilyMember(resource.data.familyId) && (
        (
          // ---- 家長 ----
          isFamilyParent(resource.data.familyId) && (
            // 核准：pending → approved
            (
              resource.data.status == 'pending'
              && request.resource.data.status == 'approved'
              && changedKeys().hasOnly(['status', 'approvedAt', 'parentNote'])
            )
            ||
            // 婉拒：pending → rejected
            (
              resource.data.status == 'pending'
              && request.resource.data.status == 'rejected'
              && changedKeys().hasOnly(['status', 'parentNote'])
            )
            ||
            // 交付：approved → delivered
            (
              resource.data.status == 'approved'
              && request.resource.data.status == 'delivered'
              && changedKeys().hasOnly(['status', 'deliveredAt', 'autoCompleteAt'])
            )
          )
        )
        ||
        (
          // ---- 訂單擁有者（小孩）----
          resource.data.userId == request.auth.uid && (
            // 確認收到：approved / delivered → completed
            (
              resource.data.status in ['approved', 'delivered']
              && request.resource.data.status == 'completed'
              && changedKeys().hasOnly(['status', 'completedAt'])
            )
            ||
            // 取消（B5 真取消）：只能在 pending 取消，避免「領獎又退點」
            (
              resource.data.status == 'pending'
              && request.resource.data.status == 'cancelled'
              && changedKeys().hasOnly(['status', 'cancelledAt'])
            )
          )
        )
      );
    }

    // ========== AI Playground Logs ==========
    // 只有 analyzePhoto CF(admin) 寫入；client 從函式回傳值取得結果，不直接讀此集合。
    match /aiPlaygroundLogs/{logId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
