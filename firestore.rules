rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helper Functions ==========

    function isSignedIn() {
      return request.auth != null;
    }

    // 檢查使用者是否為指定家庭的 active 成員（doc ID = userId_familyId）
    function isFamilyMember(familyId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)) &&
        get(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)).data.status == 'active';
    }

    // 檢查使用者是否為指定家庭的家長
    function isFamilyParent(familyId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)).data.role == 'parent' &&
        get(/databases/$(database)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)).data.status == 'active';
    }

    // ========== Users ==========
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // ========== Families ==========
    match /families/{familyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isFamilyParent(familyId);
    }

    // ========== Family Memberships ==========
    // doc ID 格式: userId_familyId
    match /familyMemberships/{membershipId} {
      allow read: if isSignedIn();
      // 只有已登入使用者可以建立自己的 membership（或家長邀請）
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
    }

    // ========== Invite Codes ==========
    match /inviteCodes/{codeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // ========== Family Invites（email 邀請）==========
    // inviteId 為隨機不可猜 doc id（= 邀請連結秘密）。允許單 doc get（接受畫面 pre-auth 顯示），
    // 禁 list；寫入只走 Cloud Functions (admin)。
    match /familyInvites/{inviteId} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    // ========== Tasks ==========
    // 只有同家庭的成員可以存取
    match /tasks/{taskId} {
      allow read: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
      allow delete: if isSignedIn() &&
        isFamilyParent(resource.data.familyId);
    }

    // ========== Task Instances ==========
    match /taskInstances/{instanceId} {
      allow read: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
    }

    // ========== Task Submissions ==========
    match /taskSubmissions/{submissionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // 允許家長更新（寫 rejectNote）
      allow update: if isSignedIn();
    }

    // ========== Point Wallets ==========
    // 建立：使用者只能建立自己的 wallet，且初始餘額必須為 0
    // 更新/刪除：只有 Cloud Functions (admin SDK)
    match /pointWallets/{walletId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.balance == 0;
      allow update, delete: if false;
    }

    // ========== Point Transactions ==========
    // 只有 Cloud Functions (admin SDK) 可以寫入
    match /pointTransactions/{transactionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ========== Reward Items ==========
    match /rewardItems/{itemId} {
      allow read: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        isFamilyParent(resource.data.familyId);
    }

    // ========== Reward Orders ==========
    match /rewardOrders/{orderId} {
      allow read: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        isFamilyMember(resource.data.familyId);
    }

    // ========== AI Playground Logs ==========
    match /aiPlaygroundLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
