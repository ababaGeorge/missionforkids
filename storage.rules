rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 檢查使用者是否為指定家庭的 active 成員（A17：與 firestore.rules 一致，須 status==active，
    // 否則被移除/停用的成員仍可存取家庭照片）
    function isFamilyMember(familyId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/familyMemberships/$(request.auth.uid + '_' + familyId))
        && firestore.get(/databases/(default)/documents/familyMemberships/$(request.auth.uid + '_' + familyId)).data.status == 'active';
    }

    // 家庭任務照片：families/{familyId}/submissions/{fileName}
    match /families/{familyId}/submissions/{fileName} {
      // 家庭成員可讀取
      allow read: if request.auth != null && isFamilyMember(familyId);

      // 家庭成員可上傳，限制 12MB、僅限圖片
      // （相機 quality 0.7 的高畫素 JPEG 可能超過 5MB，5MB 會讓旗艦機拍照提交被拒）
      allow create: if request.auth != null
                    && isFamilyMember(familyId)
                    && request.resource.size < 12 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');

      // 照片不可覆蓋或刪除
      allow update, delete: if false;
    }

    // AI Playground 照片：playground/{userId}/{fileName}
    match /playground/{userId}/{fileName} {
      // 只有本人可讀取
      allow read: if request.auth != null && request.auth.uid == userId;

      // 只有本人可上傳，限制 5MB、僅限圖片
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 12 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');

      allow update, delete: if false;
    }

    // 其他路徑一律拒絕
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
